<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Allow outgoing network connections (for FastAPI server + YouTube API) -->
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Allow local server listening (FastAPI on localhost) -->
	<key>com.apple.security.network.server</key>
	<true/>
	<!-- Allow reading/writing user-selected files (Downloads folder) -->
	<key>com.apple.security.files.user-selected.read-write</key>
	<true/>
	<!-- Allow reading/writing Downloads folder -->
	<key>com.apple.security.files.downloads.read-write</key>
	<true/>
</dict>
</plist>
